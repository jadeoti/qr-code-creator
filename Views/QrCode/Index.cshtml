@model qr_code_creator.Models.QrCodeViewModel
@{
    ViewData["Title"] = "QR Code Generator";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <h1 class="text-center mb-4">
                <i class="bi bi-qr-code"></i> QR Code Generator
            </h1>

            <form asp-controller="QrCode" asp-action="Generate" method="post">
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <!-- QR Type Selector -->
                        <ul class="nav nav-pills nav-fill mb-4" role="tablist">
                            <li class="nav-item">
                                <button type="button"
                                        class="nav-link @(Model.QrType == qr_code_creator.Models.QrType.Url ? "active" : "")"
                                        onclick="switchTab('Url')">
                                    🔗 URL
                                </button>
                            </li>
                            <li class="nav-item">
                                <button type="button"
                                        class="nav-link @(Model.QrType == qr_code_creator.Models.QrType.Wifi ? "active" : "")"
                                        onclick="switchTab('Wifi')">
                                    📶 WiFi
                                </button>
                            </li>
                        </ul>

                        <input type="hidden" asp-for="QrType" id="qrType" />

                        <!-- URL Fields -->
                        <div id="urlFields" style="display: @(Model.QrType == qr_code_creator.Models.QrType.Url ? "block" : "none")">
                            <div class="mb-3">
                                <label asp-for="Url" class="form-label fw-semibold">URL</label>
                                <input asp-for="Url" class="form-control" placeholder="https://example.com" />
                                <span asp-validation-for="Url" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- WiFi Fields -->
                        <div id="wifiFields" style="display: @(Model.QrType == qr_code_creator.Models.QrType.Wifi ? "block" : "none")">
                            <div class="mb-3">
                                <label asp-for="Ssid" class="form-label fw-semibold">Network Name (SSID)</label>
                                <input asp-for="Ssid" class="form-control" placeholder="MyWiFiNetwork" />
                                <span asp-validation-for="Ssid" class="text-danger"></span>
                            </div>
                            <div class="mb-3">
                                <label asp-for="Password" class="form-label fw-semibold">Password</label>
                                <input asp-for="Password" type="password" class="form-control" placeholder="Enter WiFi password" />
                            </div>
                            <div class="mb-3">
                                <label asp-for="AuthType" class="form-label fw-semibold">Security Type</label>
                                <select asp-for="AuthType" asp-items="Html.GetEnumSelectList<qr_code_creator.Models.WifiAuthType>()" class="form-select"></select>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 btn-lg">
                            Generate QR Code
                        </button>
                    </div>
                </div>
            </form>

            @if (!string.IsNullOrEmpty(Model.QrCodeImage))
            {
                <div class="card shadow-sm">
                    <div class="card-body text-center">
                        <h5 class="card-title mb-3">Your QR Code</h5>
                        <img src="data:image/png;base64,@Model.QrCodeImage"
                             alt="Generated QR Code"
                             class="img-fluid rounded mb-3"
                             style="max-width: 300px;" />
                        <div>
                            <a href="data:image/png;base64,@Model.QrCodeImage"
                               download="qrcode.png"
                               class="btn btn-outline-primary">
                                ⬇️ Download PNG
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function switchTab(type) {
            document.getElementById('qrType').value = type;
            document.getElementById('urlFields').style.display = type === 'Url' ? 'block' : 'none';
            document.getElementById('wifiFields').style.display = type === 'Wifi' ? 'block' : 'none';
            document.querySelectorAll('.nav-link').forEach(el => el.classList.remove('active'));
            event.target.classList.add('active');
        }
    </script>
}
